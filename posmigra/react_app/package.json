{
  "name": "customer-management-app",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop application for customer management.",
  "author": "Your Name or Company",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "electron .",
    "dev": "concurrently -k \"npm:start\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 npm run electron\"",
    "package": "npm run build:backend && vite build && electron-builder",
    "build:backend": "cd ../.. && pyinstaller posmigra/backend.spec --distpath posmigra/dist --workpath posmigra/build_py --noconfirm"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.casapro.customermanagement",
    "productName": "Customer Management App",
    "extraResources": [
      {
        "from": "../dist/pal_backend",
        "to": "pal_backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/casapro-icono.png",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "public/casapro-icono.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/casapro-icono.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/casapro-icono.png"
    }
  }
}
